<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical" android:gravity="center_horizontal"
    android:padding="24dp" android:background="#FFFFFF"
    android:layout_width="match_parent" android:layout_height="match_parent">

    <ImageView android:id="@+id/ivLogo"
        android:layout_width="120dp" android:layout_height="120dp"
        android:src="@mipmap/ic_launcher"/>

    <TextView android:id="@+id/tvTitle"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="16dp" android:textSize="22sp" android:textStyle="bold"
        android:text="Ativador"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="24dp" android:textSize="18sp"
        android:textColor="#2E7D32" android:text="✓ Ativado com sucesso"/>

    <TextView android:id="@+id/tvCode"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="8dp" android:textSize="13sp" android:textColor="#666666"/>

    <Button android:id="@+id/btnWhats"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="32dp" android:text="Falar no WhatsApp"
        android:background="#25D366" android:textColor="#FFFFFF"/>

    <Button android:id="@+id/btnSupport"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="12dp" android:text="Suporte"
        android:background="#3F51B5" android:textColor="#FFFFFF"/>

    <Button android:id="@+id/btnSettings"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="24dp" android:text="Configurações"
        android:background="#EEEEEE"/>
</LinearLayout>
