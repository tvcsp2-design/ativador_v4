<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#FFFFFF"
    android:padding="24dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView android:id="@+id/ivLogo"
        android:layout_width="140dp" android:layout_height="140dp"
        android:src="@mipmap/ic_launcher" android:contentDescription="logo"/>

    <TextView android:id="@+id/tvName"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="16dp" android:textSize="22sp" android:textStyle="bold"
        android:text="Ativador"/>

    <ProgressBar
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="24dp"/>
</LinearLayout>
